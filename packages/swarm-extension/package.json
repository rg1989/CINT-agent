{
	"type": "module",
	"name": "@incrt/cint-swarm-extension",
	"version": "16.1.16",
	"description": "Swarm orchestration extension for cint",
	"homepage": "https://github.com/rg1989/CINT-agent",
	"author": "Derek Rynd",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/incrt/cint.git",
		"directory": "packages/swarm-extension"
	},
	"bugs": {
		"url": "https://github.com/incrt/cint/issues"
	},
	"keywords": [
		"swarm",
		"orchestration",
		"agent",
		"extension"
	],
	"bin": {
		"cint-swarm": "src/cli.ts"
	},
	"scripts": {
		"check": "biome check . && bun run check:types",
		"check:types": "tsgo -p tsconfig.json --noEmit",
		"lint": "biome lint .",
		"fix": "biome check --write --unsafe .",
		"fmt": "biome format --write ."
	},
	"dependencies": {
		"@incrt/cint-utils": "workspace:*"
	},
	"devDependencies": {
		"@types/bun": "^1.3.14"
	},
	"peerDependencies": {
		"@incrt/cint": "workspace:*"
	},
	"engines": {
		"bun": ">=1.3.14"
	},
	"cint": {
		"extensions": [
			"./src/extension.ts"
		]
	},
	"files": [
		"src",
		"README.md",
		"CHANGELOG.md"
	]
}
